@page "/"
@rendermode InteractiveServer
@inject OrdersApiClient Api

<PageTitle>Pedidos</PageTitle>

<h1>Pedidos</h1>

<div style="margin-bottom: 1rem;">
    <a href="/novo">
        <button>+ Novo Pedido</button>
    </a>
</div>

@if (orders is null)
{
    <p>Carregando...</p>
}
else if (orders.Count == 0)
{
    <p>Nenhum pedido cadastrado.</p>
}
else
{
    <table style="border-collapse: collapse; width: 100%;">
        <thead>
            <tr style="background: #eee;">
                <th style="padding: 0.5rem; text-align: left;">ID</th>
                <th style="padding: 0.5rem; text-align: left;">Cliente</th>
                <th style="padding: 0.5rem; text-align: right;">Valor</th>
                <th style="padding: 0.5rem; text-align: left;">Data</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in orders)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 0.5rem;">#@order.Id</td>
                    <td style="padding: 0.5rem;">@order.Cliente</td>
                    <td style="padding: 0.5rem; text-align: right;">@order.Valor.ToString("C")</td>
                    <td style="padding: 0.5rem;">@order.DataPedido.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<OrderResponse>? orders;

    protected override async Task OnInitializedAsync()
    {
        orders = await Api.GetAllAsync();
    }
}
@page "/"
@rendermode InteractiveServer
@inject OrdersApiClient Api

<PageTitle>Pedidos</PageTitle>

<div class="header">
    <h1>Pedidos</h1>
    <a href="/novo" class="btn-primary">+ Novo Pedido</a>
</div>

@if (orders is null)
{
    <p class="status">Carregando...</p>
}
else if (orders.Count == 0)
{
    <p class="status">Nenhum pedido cadastrado.</p>
}
else
{
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Cliente</th>
                    <th class="text-right">Valor</th>
                    <th>Data</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.Cliente</td>
                        <td class="text-right">@order.Valor.ToString("C")</td>
                        <td>@order.DataPedido.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<OrderResponse>? orders;

    protected override async Task OnInitializedAsync()
    {
        orders = await Api.GetAllAsync();
    }
}
@page "/novo"
@rendermode InteractiveServer
@inject OrdersApiClient Api
@inject NavigationManager Nav

<PageTitle>Novo Pedido</PageTitle>

<h1>Novo Pedido</h1>

<div class="form-card">
    <EditForm Model="model" OnValidSubmit="Salvar" FormName="novoPedido">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />

        <div class="form-group">
            <label for="cliente">Cliente</label>
            <InputText id="cliente" @bind-Value="model.Cliente" class="form-control" />
        </div>

        <div class="form-group">
            <label for="valor">Valor</label>
            <InputNumber id="valor" @bind-Value="model.Valor" step="0.01" class="form-control" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary" disabled="@salvando">
                @(salvando ? "Enviando..." : "Cadastrar")
            </button>
            <a href="/" class="btn-link">Cancelar</a>
        </div>

        @if (mensagemErro is not null)
        {
            <p class="error-message">@mensagemErro</p>
        }
    </EditForm>
</div>

@code {
    private FormModel model = new();
    private bool salvando;
    private string? mensagemErro;

    private async Task Salvar()
    {
        salvando = true;
        mensagemErro = null;

        try
        {
            var request = new CreateOrderRequest(model.Cliente, model.Valor);
            await Api.CreateAsync(request);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            mensagemErro = $"Erro ao cadastrar: {ex.Message}";
            salvando = false;
        }
    }

    private class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Informe o cliente")]
        [System.ComponentModel.DataAnnotations.StringLength(100)]
        public string Cliente { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Range(0.01, double.MaxValue, ErrorMessage = "Valor deve ser maior que zero")]
        public decimal Valor { get; set; }
    }
}